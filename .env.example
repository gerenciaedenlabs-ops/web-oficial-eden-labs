# ─────────────────────────────────────────────────────────────
# Variables de entorno — Web oficial Eden Labs
# Copia este archivo a `.env` y rellena los valores. NO subas `.env` al repo.
# ─────────────────────────────────────────────────────────────

# URL pública del CRM (botón "Acceso clientes"). Segura de exponer.
PUBLIC_CRM_URL=https://crm.edenlabs.dev

# ── Entrega del formulario de contacto (elige UNA vía) ──────────

# Vía 1 — CRM propio (DESTINO FINAL, cuando la API esté lista).
# Si CRM_API_URL está definida, el lead se envía por POST al CRM.
# CRM_API_URL=https://crm.edenlabs.dev/api/leads
# CRM_API_KEY=tu_api_key_secreta

# Vía 2 — Puente por correo (SMTP) mientras el CRM no expone API.
# SMTP_HOST=smtp.tu-proveedor.com
# SMTP_PORT=587
# SMTP_SECURE=false          # true para el puerto 465
# SMTP_USER=usuario@edenlabs.dev
# SMTP_PASS=contraseña_o_app_password
# LEAD_TO=hola@edenlabs.dev  # a quién llegan los leads (por defecto SMTP_USER)
# LEAD_FROM=Eden Labs Web <no-reply@edenlabs.dev>
