---
const pillars = [
  {
    icon: `<path d="M12 3a9 9 0 100 18 9 9 0 000-18zM12 8v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
    title: 'Descubrimiento primero',
    text: 'Entendemos tu operación antes de escribir una sola línea de código.',
  },
  {
    icon: `<path d="M8 12h8M8 8h8M8 16h5M4 4h16v13a2 2 0 01-2 2H9l-5 4z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
    title: 'Trato directo',
    text: 'Hablas con quien construye tu software, sin intermediarios.',
  },
  {
    icon: `<path d="M7 8l-4 4 4 4M17 8l4 4-4 4M14 4l-4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
    title: 'Código mantenible',
    text: 'Entregamos sistemas que tu equipo puede operar y hacer crecer.',
  },
  {
    icon: `<path d="M12 21s-7-4.35-7-10a7 7 0 0114 0c0 5.65-7 10-7 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 11l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
    title: 'Partner de largo plazo',
    text: 'Acompañamos después del lanzamiento; no desaparecemos al entregar.',
  },
];
---

<section id="nosotros" class="py-24 md:py-32 overflow-hidden" style="background: var(--color-primary-600);">
  <div class="section-container">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">

      <!-- Left: editorial text -->
      <div class="lg:col-span-6">
        <div class="reveal">
          <div class="label-uppercase mb-6" style="color: var(--color-tertiary);">Por qué Edén Labs</div>

          <h2 class="text-4xl md:text-5xl mb-6" style="font-family: var(--font-display); color: white; letter-spacing: -0.02em;">
            El software que importa no se construye en sprint de dos semanas.
          </h2>

          <div class="space-y-4 text-lg" style="color: var(--color-primary-200); line-height: 1.7;">
            <p>
              Muchas agencias entregan código. Nosotros entregamos sistemas que la gente usa de verdad, el día que se necesitan, sin manual de 80 páginas para operarlos.
            </p>
            <p>
              La diferencia está en el descubrimiento: dedicamos tiempo real a entender tu operación antes de proponer nada. Eso hace que lo que construimos sea difícil de reemplazar —porque está hecho exactamente para ti.
            </p>
            <p>
              Trabajamos con empresas medianas y en crecimiento que ya pasaron el punto de las soluciones genéricas y necesitan un partner técnico de largo plazo, no un proveedor de turnos.
            </p>
          </div>
        </div>

        <!-- Divider -->
        <div class="mt-10 pt-10 border-t reveal reveal-delay-2" style="border-color: var(--color-primary-500);">
          <blockquote class="text-xl italic" style="font-family: var(--font-display); color: var(--color-primary-100);">
            "Nos interesa más que tu sistema crezca 3 años sin problemas, que impresionarte con un demo."
          </blockquote>
          <div class="mt-4 label-uppercase" style="color: var(--color-primary-400);">— Equipo Edén Labs</div>
        </div>
      </div>

      <!-- Right: pillars grid -->
      <div class="lg:col-span-6">
        <div class="grid sm:grid-cols-2 gap-4">
          {pillars.map((pillar, i) => (
            <div
              class={`reveal reveal-delay-${i + 1} rounded-2xl p-6`}
              style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12);"
            >
              <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-4" style="background: rgba(255,255,255,0.1); color: var(--color-tertiary);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true" set:html={pillar.icon} />
              </div>
              <div class="text-lg font-semibold mb-1.5 text-white" style="font-family: var(--font-display);">{pillar.title}</div>
              <div class="text-sm" style="color: var(--color-primary-200); line-height: 1.55;">{pillar.text}</div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
