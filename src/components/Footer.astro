---
const currentYear = new Date().getFullYear();
---

<footer style="background: var(--color-secondary-900); color: var(--color-secondary-200);">
  <div class="section-container py-16">
    <div class="grid md:grid-cols-12 gap-10">

      <!-- Brand -->
      <div class="md:col-span-4">
        <a href="/" class="inline-flex items-center gap-2 mb-5 group">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--color-primary-600);">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M9 2L15 6V12L9 16L3 12V6L9 2Z" fill="none" stroke="white" stroke-width="1.5" stroke-linejoin="round"/>
              <path d="M9 6L12 8V12L9 14L6 12V8L9 6Z" fill="white"/>
            </svg>
          </div>
          <span class="text-lg font-semibold text-white" style="font-family: var(--font-display);">Eden Labs</span>
        </a>
        <p class="text-sm mb-6" style="color: var(--color-secondary-300); line-height: 1.65; max-width: 260px;">
          Construimos software a medida para empresas que ya superaron las soluciones genéricas.
        </p>
        <div class="flex gap-3">
          {[
            { label: 'LinkedIn', href: '#', icon: `<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z" fill="currentColor"/><circle cx="4" cy="4" r="2" fill="currentColor"/>` },
            { label: 'GitHub', href: '#', icon: `<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>` },
            { label: 'X (Twitter)', href: '#', icon: `<path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>` },
          ].map((social) => (
            <a
              href={social.href}
              aria-label={social.label}
              class="w-9 h-9 rounded-lg flex items-center justify-center transition-colors duration-150 hover:text-white"
              style="background: rgba(255,255,255,0.06); color: var(--color-secondary-300);"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" set:html={social.icon}/>
            </a>
          ))}
        </div>
      </div>

      <!-- Nav links -->
      <div class="md:col-span-2">
        <div class="label-uppercase mb-4" style="color: var(--color-secondary-400);">Servicios</div>
        <ul class="space-y-2.5 text-sm" role="list">
          {['Software a medida', 'Plataformas SaaS', 'ERP e integraciones', 'Modernización'].map((item) => (
            <li><a href="#servicios" class="hover:text-white transition-colors duration-150">{item}</a></li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-2">
        <div class="label-uppercase mb-4" style="color: var(--color-secondary-400);">Empresa</div>
        <ul class="space-y-2.5 text-sm" role="list">
          {['Proceso', 'Proyectos', 'Nosotros', 'Contacto'].map((item) => (
            <li><a href={`#${item.toLowerCase()}`} class="hover:text-white transition-colors duration-150">{item}</a></li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-4">
        <div class="label-uppercase mb-4" style="color: var(--color-secondary-400);">Contacto</div>
        <ul class="space-y-2.5 text-sm" role="list">
          <li>
            <a href="mailto:hola@edenlabs.dev" class="hover:text-white transition-colors duration-150">
              hola@edenlabs.dev
            </a>
          </li>
          <li style="color: var(--color-secondary-400);">Ciudad de México · Houston, TX</li>
          <li style="color: var(--color-secondary-400);">Disponibles en hora CST/EST/CDMX</li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 flex flex-wrap items-center justify-between gap-4 text-xs border-t" style="border-color: rgba(255,255,255,0.08); color: var(--color-secondary-400);">
      <span>© {currentYear} Eden Labs. Todos los derechos reservados.</span>
      <div class="flex gap-6">
        <a href="#" class="hover:text-white transition-colors">Privacidad</a>
        <a href="#" class="hover:text-white transition-colors">Términos</a>
      </div>
    </div>
  </div>
</footer>
