---
import { SITE, SOCIALS } from '../config';

const currentYear = new Date().getFullYear();

const socialIcons: Record<string, string> = {
  Instagram: `<rect x="2.5" y="2.5" width="19" height="19" rx="5" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.6"/><circle cx="17.4" cy="6.6" r="1.2" fill="currentColor"/>`,
  TikTok: `<path d="M14 3v11.5a3.5 3.5 0 11-3.5-3.5c.35 0 .69.05 1 .14M14 3c.3 2.4 2 4.3 4.5 4.6M14 3h.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>`,
  LinkedIn: `<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z" fill="currentColor"/><circle cx="4" cy="4" r="2" fill="currentColor"/>`,
  Facebook: `<path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" fill="currentColor"/>`,
};
---

<footer style="background: var(--color-secondary-900); color: var(--color-secondary-200);">
  <div class="section-container py-16">
    <div class="grid md:grid-cols-12 gap-10">

      <!-- Brand -->
      <div class="md:col-span-4">
        <a href="/" class="inline-flex items-center mb-5 group" aria-label="Edén Labs — inicio">
          <img src="/logo-eden-white.png" alt="Edén Labs" class="h-9 w-auto" width="236" height="90" />
        </a>
        <p class="text-sm mb-6" style="color: var(--color-secondary-300); line-height: 1.65; max-width: 260px;">
          Construimos software a medida para empresas que ya superaron las soluciones genéricas.
        </p>
        <div class="flex gap-3">
          {SOCIALS.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.name}
              class="w-9 h-9 rounded-lg flex items-center justify-center transition-colors duration-150 hover:text-white"
              style="background: rgba(255,255,255,0.06); color: var(--color-secondary-300);"
            >
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" aria-hidden="true" set:html={socialIcons[social.name]}/>
            </a>
          ))}
        </div>
      </div>

      <!-- Nav links -->
      <div class="md:col-span-2">
        <div class="label-uppercase mb-4" style="color: var(--color-secondary-400);">Servicios</div>
        <ul class="space-y-2.5 text-sm" role="list">
          {['Software a medida', 'Plataformas SaaS', 'ERP e integraciones', 'Modernización'].map((item) => (
            <li><a href="#servicios" class="hover:text-white transition-colors duration-150">{item}</a></li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-2">
        <div class="label-uppercase mb-4" style="color: var(--color-secondary-400);">Empresa</div>
        <ul class="space-y-2.5 text-sm" role="list">
          {[
            { label: 'Proyectos', href: '/#proyectos' },
            { label: 'Nosotros', href: '/#nosotros' },
            { label: 'Blog', href: '/blog/' },
            { label: 'Contacto', href: '/#contacto' },
          ].map((item) => (
            <li><a href={item.href} class="hover:text-white transition-colors duration-150">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-4">
        <div class="label-uppercase mb-4" style="color: var(--color-secondary-400);">Contacto</div>
        <ul class="space-y-2.5 text-sm" role="list">
          <li>
            <a href={`mailto:${SITE.email}`} class="hover:text-white transition-colors duration-150 break-all">
              {SITE.email}
            </a>
          </li>
          <li>
            <a href={`tel:${SITE.phoneHref}`} class="hover:text-white transition-colors duration-150">
              {SITE.phoneDisplay}
            </a>
          </li>
          <li style="color: var(--color-secondary-400);">{SITE.location}</li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 flex flex-wrap items-center justify-between gap-4 text-xs border-t" style="border-color: rgba(255,255,255,0.08); color: var(--color-secondary-400);">
      <span>© {currentYear} Edén Labs. Todos los derechos reservados.</span>
      <div class="flex gap-6">
        <a href="#" class="hover:text-white transition-colors">Privacidad</a>
        <a href="#" class="hover:text-white transition-colors">Términos</a>
      </div>
    </div>
  </div>
</footer>
