---
import Button from './Button.astro';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background: transparent;"
>
  <div class="section-container">
    <nav class="flex items-center justify-between h-16 md:h-20" aria-label="Navegación principal">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group focus-visible:outline-none">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center transition-transform duration-200 group-hover:scale-105"
             style="background: var(--color-primary-600);">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M9 2L15 6V12L9 16L3 12V6L9 2Z" fill="none" stroke="white" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M9 6L12 8V12L9 14L6 12V8L9 6Z" fill="white"/>
          </svg>
        </div>
        <span class="text-xl font-semibold tracking-tight" style="font-family: var(--font-display); color: var(--color-secondary-900);">
          Eden Labs
        </span>
      </a>

      <!-- Desktop navigation -->
      <ul class="hidden md:flex items-center gap-8 list-none" role="list">
        {[
          { label: 'Servicios', href: '#servicios' },
          { label: 'Proceso', href: '#proceso' },
          { label: 'Proyectos', href: '#proyectos' },
          { label: 'Nosotros', href: '#nosotros' },
        ].map((item) => (
          <li>
            <a
              href={item.href}
              class="text-sm font-medium transition-colors duration-150 hover:text-[var(--color-primary-600)]"
              style="color: var(--color-secondary-600);"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA + Mobile toggle -->
      <div class="flex items-center gap-3">
        <Button href="#contacto" variant="primary" size="sm" class="hidden md:inline-flex">
          Hablemos
        </Button>

        <!-- Mobile menu button (island) -->
        <button
          id="mobile-menu-btn"
          class="md:hidden w-10 h-10 rounded-lg flex items-center justify-center transition-colors duration-150"
          style="background: var(--color-neutral-200);"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="icon-open" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <svg id="icon-close" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" class="hidden">
            <path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden"
    style="background: var(--color-surface); border-top: 1px solid var(--color-neutral-200);"
  >
    <div class="section-container py-6 flex flex-col gap-4">
      {[
        { label: 'Servicios', href: '#servicios' },
        { label: 'Proceso', href: '#proceso' },
        { label: 'Proyectos', href: '#proyectos' },
        { label: 'Nosotros', href: '#nosotros' },
      ].map((item) => (
        <a
          href={item.href}
          class="text-base font-medium py-2 mobile-menu-link"
          style="color: var(--color-secondary-900);"
        >
          {item.label}
        </a>
      ))}
      <Button href="#contacto" variant="primary" class="mt-2 w-full">Hablemos de tu proyecto</Button>
    </div>
  </div>
</header>

<script>
  // Scroll behaviour: opaque on scroll
  const header = document.getElementById('site-header')!;
  const updateHeader = () => {
    if (window.scrollY > 30) {
      header.style.background = 'rgba(248,250,252,0.95)';
      header.style.backdropFilter = 'blur(12px)';
      header.style.boxShadow = '0 1px 0 rgba(26,60,52,0.08)';
    } else {
      header.style.background = 'transparent';
      header.style.backdropFilter = '';
      header.style.boxShadow = '';
    }
  };
  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  btn.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    iconOpen.classList.toggle('hidden', isOpen);
    iconClose.classList.toggle('hidden', !isOpen);
  });

  document.querySelectorAll('.mobile-menu-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
