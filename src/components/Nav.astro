---
import { CRM_URL } from '../config';

const lockIcon = 'M5 8V6a3 3 0 016 0v2m-7 0h8a1 1 0 011 1v5a1 1 0 01-1 1H4a1 1 0 01-1-1V9a1 1 0 011-1z';

const navItems = [
  { label: 'Servicios', href: '/#servicios' },
  { label: 'Proyectos', href: '/#proyectos' },
  { label: 'Nosotros', href: '/#nosotros' },
  { label: 'Blog', href: '/blog/' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="section-container">
    <nav class="flex items-center justify-between h-16 md:h-20" aria-label="Navegación principal">
      <!-- Logo -->
      <a href="/" class="flex items-center focus-visible:outline-none" aria-label="Edén Labs — inicio">
        <img src="/logo-eden-white.png" alt="Edén Labs" class="logo-img logo-white h-7 md:h-8 w-auto" width="210" height="80" />
        <img src="/logo-eden.png" alt="Edén Labs" class="logo-img logo-color h-7 md:h-8 w-auto" width="210" height="80" />
      </a>

      <!-- Desktop navigation -->
      <ul class="hidden md:flex items-center gap-8 list-none" role="list">
        {navItems.map((item) => (
          <li>
            <a href={item.href} class="nav-link text-sm font-medium transition-colors duration-150">
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA + Mobile toggle -->
      <div class="flex items-center gap-3">
        <a
          href={CRM_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="nav-access hidden md:inline-flex items-center gap-1.5 text-sm font-medium transition-colors duration-150"
        >
          <svg width="15" height="15" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d={lockIcon} stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Acceso
        </a>

        <a href="/#contacto" class="nav-cta hidden md:inline-flex items-center justify-center gap-2 px-4 py-2 rounded-[10px] text-sm font-semibold transition-all duration-200">
          Hablemos
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden w-10 h-10 rounded-lg flex items-center justify-center transition-colors duration-150"
          style="background: rgba(255,255,255,0.15); color: white;"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="icon-open" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <svg id="icon-close" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" class="hidden">
            <path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden"
    style="background: var(--color-surface); border-top: 1px solid var(--color-neutral-200);"
  >
    <div class="section-container py-6 flex flex-col gap-4">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-base font-medium py-2 mobile-menu-link"
          style="color: var(--color-secondary-900);"
        >
          {item.label}
        </a>
      ))}
      <a href="/#contacto" class="mt-2 w-full inline-flex items-center justify-center gap-2 py-3 rounded-[10px] text-base font-semibold transition-all duration-200"
         style="background: var(--color-tertiary); color: var(--color-tertiary-ink);">
        Hablemos de tu proyecto
      </a>

      <a
        href={CRM_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 py-3 rounded-[10px] text-base font-medium border transition-colors duration-150"
        style="color: var(--color-secondary-900); border-color: var(--color-neutral-300);"
      >
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d={lockIcon} stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Acceso clientes
      </a>
    </div>
  </div>
</header>

<style>
  /* Estado superior: velo verde translúcido para que el nav blanco sea legible
     tanto sobre el verde del hero como sobre el panel claro diagonal. */
  #site-header {
    background: linear-gradient(to bottom, rgba(4, 39, 36, 0.82), rgba(4, 39, 36, 0.52));
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #site-header.scrolled {
    background: rgba(248, 250, 252, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 rgba(6, 78, 54, 0.08);
  }

  /* Logo: blanco arriba (sobre hero verde), a color al hacer scroll (fondo claro) */
  .logo-color { display: none; }
  #site-header.scrolled .logo-white { display: none; }
  #site-header.scrolled .logo-color { display: block; }

  /* Enlaces: claros arriba, oscuros al hacer scroll */
  .nav-link, .nav-access { color: #ffffff; }
  .nav-link:hover, .nav-access:hover { color: var(--color-tertiary-strong); }
  #site-header.scrolled .nav-link,
  #site-header.scrolled .nav-access { color: var(--color-secondary-600); }
  #site-header.scrolled .nav-link:hover,
  #site-header.scrolled .nav-access:hover { color: var(--color-primary-600); }

  /* CTA lima de marca — funciona sobre verde y sobre claro */
  .nav-cta { background: var(--color-tertiary); color: var(--color-tertiary-ink); }
  .nav-cta:hover { background: var(--color-tertiary-strong); }

  /* El botón hamburguesa se oscurece al hacer scroll */
  #site-header.scrolled #mobile-menu-btn {
    background: var(--color-neutral-200) !important;
    color: var(--color-secondary-900) !important;
  }
</style>

<script>
  // Se re-ejecuta en cada navegación (View Transitions / ClientRouter)
  const setScrolled = () => {
    const h = document.getElementById('site-header');
    if (h) h.classList.toggle('scrolled', window.scrollY > 30);
  };
  window.addEventListener('scroll', setScrolled, { passive: true });

  function initNav() {
    setScrolled();

    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');
    if (!btn || !menu || !iconOpen || !iconClose) return;

    btn.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', String(isOpen));
      iconOpen.classList.toggle('hidden', isOpen);
      iconClose.classList.toggle('hidden', !isOpen);
    });

    document.querySelectorAll('.mobile-menu-link').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
      });
    });
  }

  document.addEventListener('astro:page-load', initNav);
</script>
