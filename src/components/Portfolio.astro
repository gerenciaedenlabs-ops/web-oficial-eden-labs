---
// NOTA: borrador para revisión. Confirma/corrige alcance, tecnologías e impacto reales.
const projects = [
  {
    category: 'Sitio web',
    title: 'Sitio web para SOS Para Tu Vida',
    problem: 'Necesitaban una presencia digital clara para dar a conocer sus eventos, encuentros y escuelas, y facilitar que las personas los conocieran y contactaran.',
    solution: 'Diseñamos y desarrollamos su sitio web oficial, con una estructura clara de sus programas y un diseño responsivo pensado para convertir visitantes en contactos.',
    impact: 'Presencia digital profesional, clara y accesible desde cualquier dispositivo.',
    tags: ['Diseño web', 'Responsivo', 'SEO'],
    url: 'https://sosparatuvida.com.co/',
    accent: 'var(--color-primary-600)',
    accentBg: 'var(--color-primary-50)',
  },
  {
    category: 'E-commerce',
    title: 'Tienda online para Jewelryfashion',
    problem: 'Querían vender su catálogo de joyería y piercings en línea con una experiencia de compra confiable y acorde a su marca.',
    solution: 'Construimos su tienda e-commerce con catálogo de productos, carrito y proceso de compra, con una identidad visual alineada a la marca.',
    impact: 'Canal de venta en línea propio, con catálogo gestionable y compra directa.',
    tags: ['E-commerce', 'Catálogo', 'Checkout'],
    url: 'https://jewelryfashionoficial.com/',
    accent: 'var(--color-tertiary-ink)',
    accentBg: 'var(--color-tertiary)',
  },
];
---

<section id="proyectos" class="py-24 md:py-32" style="background: var(--color-bg);">
  <div class="section-container">

    <!-- Header -->
    <div class="flex flex-wrap items-end justify-between gap-6 mb-16 reveal">
      <div class="max-w-xl">
        <div class="label-uppercase mb-4" style="color: var(--color-primary-600);">Casos de éxito</div>
        <h2 class="text-4xl md:text-5xl" style="font-family: var(--font-display); color: var(--color-secondary-900);">
          Proyectos reales, clientes reales
        </h2>
      </div>
      <p class="text-base max-w-sm" style="color: var(--color-ink-soft);">
        Cada proyecto parte de un problema de negocio concreto. Aquí mostramos el problema que resolvimos y la solución que construimos.
      </p>
    </div>

    <!-- Projects grid -->
    <div class="grid md:grid-cols-2 gap-6">
      {projects.map((project, i) => (
        <article
          class={`reveal reveal-delay-${(i % 2) + 1} rounded-2xl overflow-hidden border transition-all duration-300`}
          style="background: var(--color-surface); border-color: var(--color-neutral-200); box-shadow: var(--shadow-sm);"
        >
          <!-- Top accent bar + category -->
          <div class="h-1.5 w-full" style={`background: ${project.accent};`}></div>

          <div class="p-8">
            <div class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium mb-5" style={`background: ${project.accentBg}; color: ${project.accent};`}>
              {project.category}
            </div>

            <h3 class="text-2xl mb-6" style="font-family: var(--font-display); color: var(--color-secondary-900);">
              {project.title}
            </h3>

            <div class="space-y-4 mb-6">
              <div>
                <div class="label-uppercase mb-1" style="color: var(--color-ink-soft);">Problema</div>
                <p class="text-sm" style="color: var(--color-secondary-600);">{project.problem}</p>
              </div>
              <div>
                <div class="label-uppercase mb-1" style="color: var(--color-ink-soft);">Solución</div>
                <p class="text-sm" style="color: var(--color-secondary-600);">{project.solution}</p>
              </div>
            </div>

            <!-- Impact -->
            <div class="rounded-xl p-4 mb-6" style={`background: ${project.accentBg};`}>
              <div class="label-uppercase mb-2" style={`color: ${project.accent};`}>Impacto</div>
              <p class="text-sm font-medium" style={`color: ${project.accent};`}>{project.impact}</p>
            </div>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="px-2.5 py-1 rounded-lg text-xs font-medium" style="background: var(--color-bg); color: var(--color-secondary-500); border: 1px solid var(--color-neutral-200);">
                  {tag}
                </span>
              ))}
            </div>

            {project.url && (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 mt-6 text-sm font-medium transition-colors duration-150"
                style={`color: ${project.accent};`}
              >
                Ver sitio
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
