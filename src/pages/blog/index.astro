---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog', ({ data }) => import.meta.env.PROD ? !data.draft : true))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const dateFmt = new Intl.DateTimeFormat('es-MX', { day: 'numeric', month: 'long', year: 'numeric' });

const [featured, ...rest] = posts;
---

<BaseLayout
  title="Blog & Insights — Eden Labs"
  description="Ideas, criterios y aprendizajes sobre software a medida, ERPs y modernización de sistemas para empresas."
>
  <Nav />
  <main>
    <!-- Header -->
    <section class="pt-32 pb-16 md:pt-40 md:pb-20" style="background: var(--color-primary-600);">
      <div class="section-container">
        <div class="label-uppercase mb-5" style="color: var(--color-tertiary);">Blog &amp; Insights</div>
        <h1 class="text-4xl md:text-6xl mb-6 max-w-3xl" style="font-family: var(--font-display); color: white; letter-spacing: -0.025em;">
          Criterio técnico, sin humo.
        </h1>
        <p class="text-lg md:text-xl max-w-xl" style="color: var(--color-primary-200); line-height: 1.65;">
          Lo que aprendemos construyendo software para empresas que exigen más. Ideas honestas sobre estrategia, arquitectura y proceso.
        </p>
      </div>
    </section>

    <section class="py-16 md:py-24" style="background: var(--color-bg);">
      <div class="section-container">
        {posts.length === 0 ? (
          <p class="text-center" style="color: var(--color-ink-soft);">Pronto publicaremos nuestros primeros artículos.</p>
        ) : (
          <>
            {/* Artículo destacado */}
            {featured && (
              <a href={`/blog/${featured.id}/`} class="group block mb-16 reveal">
                <article class="grid lg:grid-cols-2 gap-8 items-center rounded-2xl overflow-hidden p-6 md:p-8 transition-shadow duration-200"
                  style="background: var(--color-surface); box-shadow: var(--shadow-sm);">
                  <div class="aspect-[16/10] rounded-xl overflow-hidden flex items-center justify-center"
                    style="background: linear-gradient(135deg, var(--color-primary-600), var(--color-secondary-900));">
                    {featured.data.cover
                      ? <img src={featured.data.cover} alt="" class="w-full h-full object-cover" loading="lazy" />
                      : <svg width="64" height="64" viewBox="0 0 18 18" fill="none" aria-hidden="true" style="opacity:0.6;"><path d="M9 2L15 6V12L9 16L3 12V6L9 2Z" fill="none" stroke="white" stroke-width="1"/><path d="M9 6L12 8V12L9 14L6 12V8L9 6Z" fill="white" fill-opacity="0.4"/></svg>}
                  </div>
                  <div>
                    <div class="flex items-center gap-3 mb-4 text-sm" style="color: var(--color-ink-soft);">
                      <span class="px-2.5 py-1 rounded-full text-xs font-medium" style="background: var(--color-tertiary); color: var(--color-tertiary-ink);">Destacado</span>
                      <time datetime={featured.data.pubDate.toISOString()}>{dateFmt.format(featured.data.pubDate)}</time>
                    </div>
                    <h2 class="text-2xl md:text-3xl mb-3 transition-colors group-hover:text-[var(--color-primary-600)]"
                      style="font-family: var(--font-display); color: var(--color-secondary-900);">
                      {featured.data.title}
                    </h2>
                    <p class="text-base mb-5" style="color: var(--color-secondary-600); line-height: 1.6;">{featured.data.description}</p>
                    <span class="inline-flex items-center gap-1.5 text-sm font-medium" style="color: var(--color-primary-600);">
                      Leer artículo
                      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </div>
                </article>
              </a>
            )}

            {/* Resto de artículos */}
            {rest.length > 0 && (
              <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                {rest.map((post) => (
                  <a href={`/blog/${post.id}/`} class="group block reveal">
                    <article class="h-full flex flex-col rounded-2xl overflow-hidden transition-shadow duration-200"
                      style="background: var(--color-surface); box-shadow: var(--shadow-sm);">
                      <div class="aspect-[16/9] flex items-center justify-center"
                        style="background: linear-gradient(135deg, var(--color-primary-600), var(--color-secondary-900));">
                        {post.data.cover
                          ? <img src={post.data.cover} alt="" class="w-full h-full object-cover" loading="lazy" />
                          : <svg width="40" height="40" viewBox="0 0 18 18" fill="none" aria-hidden="true" style="opacity:0.5;"><path d="M9 2L15 6V12L9 16L3 12V6L9 2Z" fill="none" stroke="white" stroke-width="1"/></svg>}
                      </div>
                      <div class="flex flex-col flex-1 p-6">
                        <time class="text-xs mb-2" style="color: var(--color-ink-soft);" datetime={post.data.pubDate.toISOString()}>
                          {dateFmt.format(post.data.pubDate)}
                        </time>
                        <h3 class="text-lg mb-2 transition-colors group-hover:text-[var(--color-primary-600)]"
                          style="font-family: var(--font-display); color: var(--color-secondary-900); line-height: 1.25;">
                          {post.data.title}
                        </h3>
                        <p class="text-sm flex-1" style="color: var(--color-secondary-600); line-height: 1.55;">{post.data.description}</p>
                        {post.data.tags.length > 0 && (
                          <div class="flex flex-wrap gap-2 mt-4">
                            {post.data.tags.slice(0, 2).map((tag) => (
                              <span class="text-xs px-2 py-0.5 rounded-full" style="background: var(--color-neutral-200); color: var(--color-secondary-600);">{tag}</span>
                            ))}
                          </div>
                        )}
                      </div>
                    </article>
                  </a>
                ))}
              </div>
            )}
          </>
        )}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
